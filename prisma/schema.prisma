generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  ADMIN
}

model User {
  id        Int      @id @default(autoincrement())
  name      String
  email     String   @unique
  password  String
  role      Role     @default(USER)
  createdAt DateTime @default(now())

  leads     Lead[]   // relation
  tasks     Task[] 

}

model Lead {
  id        Int      @id @default(autoincrement())
  name      String
  email     String
  phone     String
  status    String   @default("NEW")
  createdAt DateTime @default(now())

  userId Int
  user   User @relation(fields: [userId], references: [id])
}

model Task {
  id        Int      @id @default(autoincrement())
  title     String
  status    String   @default("PENDING")
  dueDate   DateTime?

  userId    Int
  user      User     @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())
}
model Note {
  id        Int      @id @default(autoincrement())
  content   String
  createdAt DateTime @default(now())

  leadId Int
  lead   Lead @relation(fields: [leadId], references: [id])
}

model FollowUp {
  id        Int      @id @default(autoincrement())
  date      DateTime
  remark    String?
  status    String   @default("PENDING")

  leadId Int
  lead   Lead @relation(fields: [leadId], references: [id])
}